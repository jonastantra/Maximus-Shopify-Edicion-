{% comment %}
Defers the CSS using "print" media, so that the browser downloads it and loads it asynchronously.
E.g. {% render 'hs-defer-css' with filename: 'filename', pages: 'index','product','collection', local: true, minify: true %}
{% endcomment %}

{%- assign current_datetime = 'now' | date: '%s' -%}
{%- assign expire_time = shop.metaobjects['app--2675107--hyperspeed_settings']['app--2675107--hyperspeed-settings-xicnkewt'].expire_date | date: '%s' -%}
{%- if pages contains template.name -%}
  {%- if local -%}
    <link
      rel="stylesheet"
      {%- if linkId %}id="{{ linkId }}"{% endif %}
      href="{% if minify and current_datetime < expire_time %}{{ filename | asset_url | replace: '//', 'https://cdn.hyperspeed.me/script/' }}{% else %}{{ filename | asset_url }}{% endif %}"
      media="print"
      onload="this.media='all'; this.onload = null">
  {%- else -%}
    <link
      rel="stylesheet"
      {%- if linkId %}id="{{ linkId }}"{% endif %}
      href="{% if minify and current_datetime < expire_time %}{{ filename | replace: '//', 'https://cdn.hyperspeed.me/script/' }}{% else %}{{ filename }}{% endif %}"
      media="print"
      onload="this.media='all'; this.onload = null">
  {%- endif -%}
{%- else -%}
  {%- if local -%}
    <link
      rel="stylesheet"
      {%- if linkId %}id="{{ linkId }}"{% endif %}
      href="{% if minify and current_datetime < expire_time %}{{ filename | asset_url | replace: '//', 'https://cdn.hyperspeed.me/script/' }}{% else %}{{ filename | asset_url }}{% endif %}">
  {%- else -%}
    <link
      rel="stylesheet"
      {%- if linkId %}id="{{ linkId }}"{% endif %}
      href="{% if minify and current_datetime < expire_time %}{{ filename | replace: '//', 'https://cdn.hyperspeed.me/script/' }}{% else %}{{ filename }}{% endif %}">
  {%- endif -%}
{%- endif -%}