      "settings": {
        "custom_liquid": "<style>\n  .mx-cmp__grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 56px;\n    align-items: center;\n  }\n  .mx-cmp__text { display: flex; flex-direction: column; }\n  .mx-cmp__copy p {\n    font-size: 15px;\n    color: var(--mx-text);\n    line-height: 1.7;\n    margin: 0 0 12px;\n  }\n  .mx-cmp__benefits {\n    margin: 24px 0 28px;\n    display: flex;\n    flex-direction: column;\n    gap: 14px;\n  }\n  .mx-cmp__benefit {\n    display: flex;\n    align-items: center;\n    font-size: 15px;\n    color: var(--mx-heading);\n    gap: 12px;\n  }\n  .mx-cmp__check {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 22px;\n    height: 22px;\n    border-radius: 50%;\n    background: var(--mx-gold);\n    color: #fff;\n    font-size: 12px;\n    flex-shrink: 0;\n  }\n  .mx-cmp__table {\n    display: flex;\n    flex-direction: column;\n    background: #fff;\n    border: 1px solid var(--mx-border);\n    border-radius: 4px;\n    overflow: hidden;\n    box-shadow: 0 4px 16px rgba(26,24,20,0.06);\n  }\n  .mx-cmp__row {\n    display: flex;\n    align-items: stretch;\n    border-bottom: 1px solid var(--mx-border);\n  }\n  .mx-cmp__row:last-child { border-bottom: none; }\n  .mx-cmp__cell-text {\n    flex: 2;\n    padding: 14px 16px;\n    background: #fff;\n    display: flex;\n    align-items: center;\n    font-weight: 500;\n    font-size: 13px;\n    line-height: 1.4;\n    color: var(--mx-heading);\n  }\n  .mx-cmp__cell-brand,\n  .mx-cmp__cell-other {\n    flex: 1;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 12px 5px;\n    text-align: center;\n  }\n  .mx-cmp__cell-brand { background: var(--mx-heading); color: var(--mx-gold); border-left: 1px solid rgba(255,255,255,0.08); }\n  .mx-cmp__cell-other { background: #fff; color: var(--mx-text); border-left: 1px solid var(--mx-border); }\n  .mx-cmp__head {\n    font-family: var(--mx-font-display);\n    font-size: 14px;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n  }\n  .mx-cmp__icon-svg { width: 22px; height: 22px; display: block; }\n  .mx-cmp__icon-check { stroke: var(--mx-gold); }\n  .mx-cmp__icon-cross { stroke: var(--mx-text-soft); }\n  .mx-cmp__cta-wrap { margin-top: 8px; }\n  @media (max-width: 760px) {\n    .mx-cmp__grid { grid-template-columns: 1fr; gap: 36px; }\n    .mx-cmp__cell-text { font-size: 12px; padding: 12px; }\n  }\n</style>\n\n<section class=\"mx-section mx-section--white\">\n  <div class=\"mx-section__inner\">\n    <div class=\"mx-cmp__grid\">\n\n      <div class=\"mx-cmp__text\">\n        <p class=\"mx-eyebrow mx-eyebrow--solo\">Por qué Maximus</p>\n        <h2 class=\"mx-title\">¿Por qué deberías probar <span class=\"mx-title__accent\">MAXIMUS INC</span>?</h2>\n        <hr class=\"mx-divider\">\n        <div class=\"mx-cmp__copy\">\n          <p>Desde 2015 cambiando la historia. Con fórmulas 100% originales, sin falsas promesas.</p>\n          <p>Calidad y seguridad en cada aplicación. La familia sigue creciendo, ¿te unes?</p>\n        </div>\n\n        <div class=\"mx-cmp__benefits\">\n          <div class=\"mx-cmp__benefit\"><span class=\"mx-cmp__check\">✓</span> Marca establecida</div>\n          <div class=\"mx-cmp__benefit\"><span class=\"mx-cmp__check\">✓</span> Envíos rápidos</div>\n          <div class=\"mx-cmp__benefit\"><span class=\"mx-cmp__check\">✓</span> Soporte directo</div>\n        </div>\n\n        <div class=\"mx-cmp__cta-wrap\">\n          <a href=\"#Tag-Comprar\" class=\"mx-btn mx-btn--primary\">Empezar mi tratamiento · garantía 30 días →</a>\n        </div>\n      </div>\n\n      <div>\n        <div class=\"mx-cmp__table\">\n          <div class=\"mx-cmp__row\">\n            <div class=\"mx-cmp__cell-text\"></div>\n            <div class=\"mx-cmp__cell-brand mx-cmp__head\">MAXIMUS</div>\n            <div class=\"mx-cmp__cell-other mx-cmp__head\">OTROS</div>\n          </div>\n\n          {% assign rows = \"Fórmulas 100% originales y exclusivas|Activos clínicamente probados|Miles de clientes satisfechos|Resultados reales y permanentes|Calidad y seguridad garantizada\" | split: \"|\" %}\n          {% for r in rows %}\n          <div class=\"mx-cmp__row\">\n            <div class=\"mx-cmp__cell-text\">{{ r }}</div>\n            <div class=\"mx-cmp__cell-brand\">\n              <svg class=\"mx-cmp__icon-svg mx-cmp__icon-check\" viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 6L9 17L4 12\"/></svg>\n            </div>\n            <div class=\"mx-cmp__cell-other\">\n              <svg class=\"mx-cmp__icon-svg mx-cmp__icon-cross\" viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M18 6L6 18\"/><path d=\"M6 6L18 18\"/></svg>\n            </div>\n          </div>\n          {% endfor %}\n        </div>\n      </div>\n\n    </div>\n  </div>\n</section>",
