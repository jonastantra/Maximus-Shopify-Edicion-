      "settings": {
        "custom_liquid": "<style>\n  .mx-prog__grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 20px;\n    position: relative;\n  }\n  .mx-prog__item {\n    display: flex;\n    flex-direction: column;\n    position: relative;\n  }\n  .mx-prog__chip {\n    align-self: center;\n    margin-bottom: 14px;\n    display: inline-flex;\n    align-items: center;\n    gap: 6px;\n    padding: 5px 12px;\n    background: #fff;\n    border: 1px solid var(--mx-gold-soft);\n    border-radius: 100px;\n    font-family: var(--mx-font-display);\n    font-size: 11px;\n    letter-spacing: 0.22em;\n    color: var(--mx-gold);\n    white-space: nowrap;\n  }\n  .mx-prog__chip-num {\n    color: rgba(184,154,82,0.5);\n    font-size: 10px;\n  }\n  .mx-prog__photo {\n    position: relative;\n    width: 100%;\n    aspect-ratio: 3/4;\n    overflow: hidden;\n    border-radius: 3px;\n    background: #dedad3;\n  }\n  .mx-prog__photo img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    object-position: center 20%;\n    display: block;\n    transition: transform 0.6s ease;\n  }\n  .mx-prog__photo:hover img { transform: scale(1.05); }\n  .mx-prog__item--before .mx-prog__photo img {\n    filter: grayscale(45%) brightness(0.95);\n  }\n  .mx-prog__item--before .mx-prog__photo::after {\n    content: '';\n    position: absolute;\n    inset: 0;\n    border: 1px solid rgba(122,117,112,0.3);\n    border-radius: 3px;\n    pointer-events: none;\n  }\n  .mx-prog__item--final .mx-prog__photo {\n    box-shadow:\n      0 0 0 1px var(--mx-gold-soft),\n      0 20px 50px rgba(184,154,82,0.25),\n      0 2px 8px rgba(26,24,20,0.08);\n  }\n  .mx-prog__item--final .mx-prog__photo::after {\n    content: '';\n    position: absolute;\n    inset: 0;\n    border: 2px solid var(--mx-gold);\n    border-radius: 3px;\n    pointer-events: none;\n  }\n  .mx-prog__tag-best {\n    position: absolute;\n    top: 10px;\n    right: 10px;\n    background: var(--mx-gold);\n    color: #fff;\n    font-family: var(--mx-font-display);\n    font-size: 10px;\n    letter-spacing: 0.2em;\n    padding: 4px 10px;\n    border-radius: 2px;\n    z-index: 2;\n    box-shadow: 0 2px 8px rgba(26,24,20,0.2);\n  }\n  .mx-prog__info {\n    margin-top: 20px;\n    text-align: center;\n  }\n  .mx-prog__week {\n    font-family: var(--mx-font-display);\n    font-size: 26px;\n    letter-spacing: 0.03em;\n    color: var(--mx-heading);\n    margin: 0 0 6px;\n    line-height: 1;\n  }\n  .mx-prog__desc {\n    font-size: 10px;\n    letter-spacing: 0.28em;\n    text-transform: uppercase;\n    color: var(--mx-text-soft);\n    margin: 0;\n    font-weight: 500;\n  }\n  .mx-prog__item--before .mx-prog__week { color: var(--mx-text-soft); }\n  .mx-prog__item--final .mx-prog__week { color: var(--mx-gold); }\n  .mx-prog__item--final .mx-prog__desc { color: var(--mx-gold); font-weight: 600; }\n  .mx-prog__connector {\n    position: absolute;\n    top: 42%;\n    right: -14px;\n    width: 20px;\n    height: 20px;\n    transform: translateY(-50%);\n    z-index: 3;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  .mx-prog__connector::before {\n    content: '';\n    position: absolute;\n    left: -40px;\n    width: 80px;\n    height: 1px;\n    background: var(--mx-gold-soft);\n  }\n  .mx-prog__connector svg {\n    position: relative;\n    z-index: 2;\n    background: var(--mx-bg);\n    padding: 2px;\n  }\n  .mx-prog__item:last-child .mx-prog__connector { display: none; }\n  .mx-prog__stats {\n    margin-top: 64px;\n    padding-top: 40px;\n    border-top: 1px solid var(--mx-gold-faint);\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 20px;\n  }\n  .mx-prog__stat { text-align: center; }\n  .mx-prog__stat-num {\n    font-family: var(--mx-font-display);\n    font-size: 38px;\n    letter-spacing: 0.02em;\n    color: var(--mx-gold);\n    margin: 0 0 6px;\n    line-height: 1;\n  }\n  .mx-prog__stat-label {\n    font-size: 11px;\n    letter-spacing: 0.2em;\n    text-transform: uppercase;\n    color: var(--mx-text-mute);\n    margin: 0;\n    font-weight: 500;\n  }\n  .mx-prog__rating-wrap {\n    display: flex;\n    justify-content: center;\n    margin-bottom: 24px;\n  }\n  @media (max-width: 760px) {\n    .mx-prog__grid {\n      grid-template-columns: 1fr 1fr;\n      gap: 32px 12px;\n    }\n    .mx-prog__connector { display: none; }\n    .mx-prog__week { font-size: 20px; }\n    .mx-prog__desc { font-size: 9px; letter-spacing: 0.2em; }\n    .mx-prog__chip { font-size: 10px; padding: 4px 10px; }\n    .mx-prog__stats {\n      grid-template-columns: 1fr;\n      gap: 24px;\n      margin-top: 48px;\n      padding-top: 32px;\n    }\n    .mx-prog__stat-num { font-size: 32px; }\n  }\n</style>\n\n<section class=\"mx-section\">\n  <div class=\"mx-section__inner\">\n\n    <div class=\"mx-prog__rating-wrap\">\n      <div class=\"mx-rating-pill\">\n        <span class=\"mx-rating-pill__stars\">★★★★★</span>\n        <span class=\"mx-rating-pill__score\">4.9</span>\n        <span class=\"mx-rating-pill__dot\"></span>\n        <span class=\"mx-rating-pill__count\">700 reseñas verificadas</span>\n      </div>\n    </div>\n\n    <div class=\"mx-section__head\">\n      <p class=\"mx-eyebrow\">Progreso real documentado</p>\n      <h2 class=\"mx-title\">Resultados desde la<br><span class=\"mx-title__accent\">semana 4</span></h2>\n      <p class=\"mx-subtitle\">Fórmula de Minoxidil al 20% diseñada exclusivamente para barba</p>\n    </div>\n\n    <div class=\"mx-prog__grid\">\n\n      {% assign img_antes = \"https://cdn.shopify.com/s/files/1/0568/3904/5282/files/503522624_4117710965172105_6153995748490095670_n.jpg?v=1771942872\" %}\n      <div class=\"mx-prog__item mx-prog__item--before\">\n        <span class=\"mx-prog__chip\"><span class=\"mx-prog__chip-num\">01</span> Inicio</span>\n        <div class=\"mx-prog__photo\">\n          <img src=\"{{ img_antes }}\" alt=\"Antes de usar Maximus\" loading=\"lazy\">\n        </div>\n     