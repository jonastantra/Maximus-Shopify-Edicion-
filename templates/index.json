ctor\">\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><path d=\"M1 7h11m0 0L7.5 2.5M12 7L7.5 11.5\" stroke=\"#b89a52\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </span>\n      </div>\n\n      {% assign img_s8 = \"https://cdn.shopify.com/s/files/1/0568/3904/5282/files/503953787_4117710945172107_6503352951328210824_n_1.jpg?v=1771942872\" %}\n      <div class=\"mx-prog__item mx-prog__item--final\">\n        <span class=\"mx-prog__chip\"><span class=\"mx-prog__chip-num\">04</span> Resultado</span>\n        <div class=\"mx-prog__photo\">\n          <span class=\"mx-prog__tag-best\">Mejor versión</span>\n          <img src=\"{{ img_s8 }}\" alt=\"8 semanas de uso Maximus\" loading=\"lazy\">\n        </div>\n        <div class=\"mx-prog__info\">\n          <p class=\"mx-prog__week\">Semana 8</p>\n          <p class=\"mx-prog__desc\">Barba definida</p>\n        </div>\n      </div>\n\n    </div>\n\n    <div class=\"mx-prog__stats\">\n      <div class=\"mx-prog__stat\">\n        <p class=\"mx-prog__stat-num\">20%</p>\n        <p class=\"mx-prog__stat-label\">Minoxidil puro</p>\n      </div>\n      <div class=\"mx-prog__stat\">\n        <p class=\"mx-prog__stat-num\">8 sem.</p>\n        <p class=\"mx-prog__stat-label\">Barba definida</p>\n      </div>\n      <div class=\"mx-prog__stat\">\n        <p class=\"mx-prog__stat-num\">700+</p>\n        <p class=\"mx-prog__stat-label\">Clientes satisfechos</p>\n      </div>\n    </div>\n\n  </div>\n</section>",
