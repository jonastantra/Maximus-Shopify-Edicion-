{%- assign whatsapp_href = settings.social_whatsapp_link -%}
{%- if whatsapp_href != blank -%}
  <div class="lumbeard-whatsapp-widget" data-whatsapp-widget>
    <div class="lumbeard-whatsapp-bubble" data-whatsapp-bubble role="status" aria-live="polite">
      <span class="lumbeard-whatsapp-bubble__text">¿En qué podemos ayudarte?</span>
      <button class="lumbeard-whatsapp-bubble__close" type="button" data-whatsapp-close aria-label="Cerrar mensaje de WhatsApp">
        <span aria-hidden="true">×</span>
      </button>
    </div>

    <a
      class="lumbeard-whatsapp-float"
      href="{{ whatsapp_href }}"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Abrir WhatsApp"
    >
      <svg viewBox="0 0 32 32" aria-hidden="true" focusable="false">
        <path d="M16.04 3C8.86 3 3 8.77 3 15.86c0 2.27.62 4.49 1.78 6.43L3.1 29l6.88-1.77a13.1 13.1 0 0 0 6.06 1.48C23.23 28.71 29 22.95 29 15.86S23.23 3 16.04 3Zm0 23.47c-1.91 0-3.77-.51-5.4-1.48l-.39-.23-4.08 1.05 1.08-3.96-.26-.41a10.54 10.54 0 0 1-1.62-5.58c0-5.86 4.79-10.62 10.67-10.62 5.87 0 10.64 4.76 10.64 10.62 0 5.85-4.77 10.61-10.64 10.61Zm5.84-7.94c-.32-.16-1.88-.92-2.17-1.03-.29-.1-.5-.16-.71.16-.21.31-.82 1.02-1 1.23-.18.21-.37.23-.69.08-.32-.16-1.35-.49-2.57-1.58-.95-.84-1.59-1.88-1.78-2.2-.18-.31-.02-.49.14-.65.14-.14.32-.37.48-.55.16-.18.21-.31.32-.52.11-.21.05-.39-.03-.55-.08-.16-.71-1.7-.97-2.32-.26-.61-.52-.53-.71-.54h-.61c-.21 0-.55.08-.84.39-.29.31-1.11 1.08-1.11 2.64s1.14 3.07 1.3 3.28c.16.21 2.25 3.41 5.45 4.78.76.33 1.35.52 1.81.67.76.24 1.46.21 2.01.13.61-.09 1.88-.76 2.14-1.5.26-.73.26-1.36.18-1.5-.08-.13-.29-.21-.61-.37Z"/>
      </svg>
      <span>WhatsApp</span>
    </a>
  </div>

  <style>
    .lumbeard-whatsapp-widget {
      position: fixed;
      right: 20px;
      bottom: 20px;
      z-index: 90;
      display: flex;
      align-items: center;
      gap: 12px;
      opacity: 0;
      pointer-events: none;
      transform: translateY(16px) scale(.96);
      transition: opacity .22s ease, transform .22s ease;
    }

    .lumbeard-whatsapp-widget.is-visible {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0) scale(1);
    }

    .lumbeard-whatsapp-bubble {
      position: relative;
      display: flex;
      align-items: center;
      gap: 12px;
      min-height: 54px;
      max-width: min(320px, calc(100vw - 112px));
      padding: 13px 16px 13px 18px;
      background: #fff;
      color: #0c0b0a;
      border: 1px solid rgba(183, 148, 70, .28);
      border-radius: 4px;
      box-shadow: 0 16px 38px rgba(12, 11, 10, .18);
      transform: translateX(0);
      opacity: 0;
      visibility: hidden;
      transition: opacity .2s ease, visibility .2s ease, transform .22s ease;
    }

    .lumbeard-whatsapp-bubble::after {
      content: '';
      position: absolute;
      right: -8px;
      top: 50%;
      width: 14px;
      height: 14px;
      background: #fff;
      border-top: 1px solid rgba(183, 148, 70, .28);
      border-right: 1px solid rgba(183, 148, 70, .28);
      transform: translateY(-50%) rotate(45deg);
    }

    .lumbeard-whatsapp-widget.is-bubble-open .lumbeard-whatsapp-bubble {
      opacity: 1;
      visibility: visible;
      transform: translateX(0);
    }

    .lumbeard-whatsapp-widget.is-bubble-closed .lumbeard-whatsapp-bubble {
      opacity: 0;
      visibility: hidden;
      transform: translateX(14px);
    }

    .lumbeard-whatsapp-bubble__text {
      font-family: var(--mx-font-display, 'Bebas Neue', Impact, sans-serif);
      font-size: 20px;
      font-weight: 400;
      line-height: 1.05;
      letter-spacing: .03em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .lumbeard-whatsapp-bubble__close {
      position: relative;
      z-index: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      flex: 0 0 auto;
      border: 1px solid rgba(12, 11, 10, .12);
      border-radius: 50%;
      background: #f7f6f2;
      color: #0c0b0a;
      cursor: pointer;
      font-size: 18px;
      line-height: 1;
      padding: 0;
    }

    .lumbeard-whatsapp-float {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      min-height: 58px;
      padding: 0 18px;
      color: #fff;
      background: linear-gradient(135deg, #25d366 0%, #128c7e 100%);
      border: 2px solid rgba(255, 255, 255, .9);
      border-radius: 999px;
      box-shadow: 0 16px 34px rgba(18, 140, 126, .36), 0 0 0 8px rgba(37, 211, 102, .12);
      font-weight: 800;
      line-height: 1;
      text-decoration: none;
      transition: transform .18s ease, box-shadow .18s ease;
    }

    .lumbeard-whatsapp-float svg {
      width: 28px;
      height: 28px;
      fill: currentColor;
    }

    .lumbeard-whatsapp-float:hover {
      color: #fff;
      transform: translateY(-2px) scale(1.03);
      box-shadow: 0 20px 42px rgba(18, 140, 126, .46), 0 0 0 10px rgba(37, 211, 102, .16);
    }

    @media screen and (max-width: 749px) {
      .lumbeard-whatsapp-widget {
        right: 14px;
        bottom: 85px;
        gap: 10px;
      }

      .lumbeard-whatsapp-bubble {
        max-width: calc(100vw - 100px);
        min-height: 50px;
        padding: 12px 12px 12px 14px;
      }

      .lumbeard-whatsapp-bubble__text {
        font-size: 17px;
        white-space: normal;
      }

      .lumbeard-whatsapp-float {
        width: 58px;
        height: 58px;
        min-height: 58px;
        padding: 0;
        border-radius: 50%;
        flex: 0 0 auto;
      }

      .lumbeard-whatsapp-float span {
        position: absolute;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
      }
    }
  </style>

  <script>
    (function() {
      var widget = document.querySelector('[data-whatsapp-widget]');
      if (!widget) return;

      var close = widget.querySelector('[data-whatsapp-close]');
      var bubbleTimer = null;
      var hasShownBubble = false;

      function getRevealPoint() {
        return 80;
      }

      function closeBubble() {
        widget.classList.remove('is-bubble-open');
        widget.classList.add('is-bubble-closed');
        if (bubbleTimer) {
          window.clearTimeout(bubbleTimer);
          bubbleTimer = null;
        }
      }

      function openBubbleOnce() {
        if (hasShownBubble || widget.classList.contains('is-bubble-closed-manual')) return;
        hasShownBubble = true;
        widget.classList.add('is-bubble-open');
        widget.classList.remove('is-bubble-closed');
        bubbleTimer = window.setTimeout(closeBubble, 4000);
      }

      function updateVisibility() {
        var shouldShow = window.scrollY > getRevealPoint();
        widget.classList.toggle('is-visible', shouldShow);
        if (shouldShow) openBubbleOnce();
      }

      if (close) {
        close.addEventListener('click', function(event) {
          event.preventDefault();
          event.stopPropagation();
          widget.classList.add('is-bubble-closed-manual');
          closeBubble();
        });
      }

      updateVisibility();
      window.addEventListener('scroll', updateVisibility, { passive: true });
      window.addEventListener('resize', updateVisibility);
      document.addEventListener('shopify:section:load', updateVisibility);
    })();
  </script>
{%- endif -%}
