{% comment %}All custom CSS in this file will be kept when updating the theme Write your custom CSS below .featured-logos{padding:20px;background:#f3f3f3;text-align:center}.featured-logos h2{font-size:22px;font-weight:700;margin-bottom:20px}.logo-grid{display:flex;flex-wrap:wrap;justify-content:center;gap:20px}.logo-grid .logo-box{background:#fff;border-radius:10px;padding:12px 16px;flex:1 1 180px;max-width:220px;display:flex;align-items:center;justify-content:center;height:80px}.logo-grid .logo-box img{max-height:50px;max-width:100%;object-fit:contain}@media screen and (max-width:768px){.logo-grid{flex-direction:row;flex-wrap:wrap}.logo-grid .logo-box{flex:0 1 calc(50% - 20px)}}.maximus-benefits *{margin:0;padding:0;box-sizing:border-box}.maximus-benefits{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background-color:#f8f9fa;padding:40px 20px}.maximus-benefits-container{max-width:1200px;margin:0 auto;background:#fff;border-radius:16px;padding:40px;box-shadow:0 8px 32px rgb(0 0 0 / .1)}.maximus-header{text-align:center;margin-bottom:40px}.maximus-header h2{font-size:32px;font-weight:700;color:#2d3748;margin-bottom:8px}.maximus-header .emoji{font-size:36px;margin-left:8px}.maximus-benefits-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:24px;margin-bottom:60px}.maximus-benefit-item{display:flex;align-items:center;padding:20px;background:#f8f9fa;border-radius:12px;transition:all 0.3s ease}.maximus-benefit-item:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgb(0 0 0 / .1)}.maximus-benefit-icon{width:48px;height:48px;margin-right:16px;flex-shrink:0}.maximus-benefit-icon.special{background:#00d4aa;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:24px;font-weight:700}.maximus-benefit-text{flex:1;font-size:16px;font-weight:600;color:#2d3748}.maximus-checkmark{width:24px;height:24px;background:#22c55e;border-radius:50%;display:flex;align-items:center;justify-content:center;margin-left:12px;flex-shrink:0}.maximus-detailed-benefits{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:32px;margin-top:60px}.maximus-detailed-item{text-align:center;padding:24px;background:#f8f9fa;border-radius:16px}.maximus-detailed-item .icon{width:60px;height:60px;margin:0 auto 16px}.maximus-detailed-item .icon.special{background:#00d4aa;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:28px;font-weight:700}.maximus-detailed-item h3{font-size:18px;font-weight:700;color:#2d3748;margin-bottom:12px}.maximus-detailed-item p{font-size:14px;color:#4a5568;line-height:1.5}@media (max-width:768px){.maximus-benefits-container{padding:24px}.maximus-header h2{font-size:24px}.maximus-benefits-grid{grid-template-columns:1fr}.maximus-detailed-benefits{grid-template-columns:1fr;gap:24px}}.why-choose-table-container{max-width:960px;margin:0 auto 50px;padding:10px;font-family:'Helvetica Neue',sans-serif;background:#f8fafd;border-radius:12px}.why-choose-table-title{text-align:center;font-size:30px;font-weight:800;color:#111;margin-bottom:8px}.why-choose-table-subtitle{text-align:center;font-size:16px;color:#555;margin-bottom:25px}.why-choose-table{width:100%;border-collapse:collapse;box-shadow:0 6px 18px rgb(0 0 0 / .06);border-radius:12px;overflow:hidden;background:#fff}.why-choose-table th,.why-choose-table td{border:1px solid #e0e0e0;padding:14px 10px;text-align:center;font-size:15px}.why-choose-table th{background-color:#f2f2f2;font-weight:700;color:#222}.why-choose-feature{text-align:left;background:linear-gradient(135deg,#28a29c,#42c189);color:#fff;font-weight:600;padding-left:15px}.why-choose-check{color:#28a745;font-size:20px;font-weight:700}.why-choose-cross{color:#d33333;font-size:20px;font-weight:700}@media (max-width:600px){.why-choose-table-title{font-size:24px}.why-choose-table th,.why-choose-table td{font-size:13px;padding:10px 6px}}{% endcomment %}