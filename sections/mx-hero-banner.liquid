<script>
  (function() {
    function loadDeferredSlides() {
      var isMobile = window.matchMedia && window.matchMedia('(max-width: 767px)').matches;

      document.querySelectorAll('.mx-hero__slide img[data-src]').forEach(function(img) {
        var picture = img.closest('picture');
        var mobileSource = picture ? picture.querySelector('[data-srcset]') : null;

        if (isMobile && mobileSource) {
          var mobileUrl = mobileSource.getAttribute('data-srcset');
          mobileSource.setAttribute('srcset', mobileUrl);
          mobileSource.removeAttribute('data-srcset');
          img.src = mobileUrl;
        } else {
          img.src = img.getAttribute('data-src');
        }

        img.removeAttribute('data-src');
      });

      if (!isMobile) {
        document.querySelectorAll('.mx-hero__slide [data-srcset]').forEach(function(source) {
          source.removeAttribute('data-srcset');
        });
      }
    }

    function handleScrollClick(e) {
      var href = this.getAttribute('href');
      if (!href || href.charAt(0) !== '#') return;

      var targetEl = document.getElementById(href.substring(1));
      if (!targetEl) return;

      e.preventDefault();
      var offset = window.innerWidth < 768 ? 100 : 120;
      var elementPosition = targetEl.getBoundingClientRect().top + window.pageYOffset;

      window.scrollTo({
        top: elementPosition - offset,
        behavior: 'smooth'
      });
    }

    function setupScroll() {
      document.querySelectorAll('.mx-hero__btn').forEach(function(heroBtn) {
        heroBtn.removeEventListener('click', handleScrollClick);
        heroBtn.addEventListener('click', handleScrollClick);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        setupScroll();
        setTimeout(loadDeferredSlides, 900);
      });
    } else {
      setupScroll();
      setTimeout(loadDeferredSlides, 900);
    }

    document.addEventListener('shopify:section:load', setupScroll);
  })();
</script>

{% schema %}
{
  "name": "MX Hero Banner",
  "tag": "section",
  "class": "mx-hero-banner-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Copete / Ceja",
      "default": "BALSAMO NUMERO UNO"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "EL MEJOR CRECIMIENTO"
    },
    {
      "type": "text",
      "id": "title_accent",
      "label": "Titulo acento",
      "default": "DE MEXICO"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripcion",
      "default": "Despierta foliculos dormidos, rellena zonas vacias y define tu caracter con una formula potente, premium y enfocada en barba."
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Texto del boton",
      "default": "INICIAR MI CAMBIO AHORA"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Enlace del boton"
    }
  ],
  "presets": [
    {
      "name": "MX Hero Banner"
    }
  ]
}
{% endschema %}
