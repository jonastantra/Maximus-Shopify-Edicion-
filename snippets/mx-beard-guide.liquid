<div class="mx-beard-guide">
  <p class="mx-beard-guide__title">Guía: Elige según tu tipo de barba</p>
  <div class="mx-beard-guide__grid">
    
    <div class="mx-beard-guide__item" onclick="mxSelectBundle(0)">
      <span class="mx-beard-guide__badge">Fase Inicial</span>
      <p class="mx-beard-guide__option">1 Bote</p>
      <p class="mx-beard-guide__duration">1.5 Meses de Uso</p>
      <div class="mx-beard-guide__points">
        <div class="mx-beard-guide__point">Rellena huecos pequeños</div>
        <div class="mx-beard-guide__point">Ideal para detallar y perfilar</div>
        <div class="mx-beard-guide__point">Engrosa vello fino existente</div>
      </div>
      <p class="mx-beard-guide__footer">Ideal para probar textura y tolerancia</p>
    </div>

    <div class="mx-beard-guide__item is-popular" onclick="mxSelectBundle(1)">
      <span class="mx-beard-guide__badge mx-beard-guide__badge--gold">Recomendado</span>
      <p class="mx-beard-guide__option">2 Botes</p>
      <p class="mx-beard-guide__duration">3 Meses de Uso</p>
      <div class="mx-beard-guide__points">
        <div class="mx-beard-guide__point">Cierra parches grandes y mejillas</div>
        <div class="mx-beard-guide__point"><strong>Ciclo biológico mínimo</strong></div>
        <div class="mx-beard-guide__point"><strong>Envío Express GRATIS</strong></div>
      </div>
      <p class="mx-beard-guide__footer mx-beard-guide__footer--gold">Evita que el vello nuevo se caiga al suspender</p>
    </div>

  </div>
</div>

<script>
  function mxSelectBundle(index) {
    // 1. Highlight clicked card in the guide
    var items = document.querySelectorAll('.mx-beard-guide__item');
    items.forEach(function(item, idx) {
      if (idx === index) {
        item.classList.add('is-selected');
      } else {
        item.classList.remove('is-selected');
      }
    });

    // 2. Select in Kaching Bundles
    var kachingSelectors = [
      '.kaching-bundles__deal',
      '.kaching-bundles__deal-card',
      '[class*="kaching-bundles__deal"]',
      '[class*="deal-card"]',
      '.kaching-bundle-deal',
      '[data-deal-id]'
    ];
    
    var clicked = false;
    for (var i = 0; i < kachingSelectors.length; i++) {
      var elements = document.querySelectorAll(kachingSelectors[i]);
      if (elements && elements.length > index) {
        elements[index].click();
        clicked = true;
        break;
      }
    }

    if (!clicked) {
      var inputs = document.querySelectorAll('input[type="radio"][name*="kaching"], [class*="kaching"] input[type="radio"]');
      if (inputs && inputs.length > index) {
        inputs[index].click();
      }
    }
  }

  // Sync back when Kaching is clicked directly
  (function() {
    function setupKachingSync() {
      var container = document.querySelector('[class*="kaching-bundles"]');
      if (!container) return;

      container.addEventListener('click', function(e) {
        var dealCard = e.target.closest('.kaching-bundles__deal, .kaching-bundles__deal-card, [class*="kaching-bundles__deal"], [class*="deal-card"]');
        if (!dealCard) return;

        var cards = Array.from(container.querySelectorAll('.kaching-bundles__deal, .kaching-bundles__deal-card, [class*="kaching-bundles__deal"], [class*="deal-card"]'));
        var index = cards.indexOf(dealCard);
        
        if (index >= 0 && index < 2) {
          var guideItems = document.querySelectorAll('.mx-beard-guide__item');
          guideItems.forEach(function(item, idx) {
            item.classList.toggle('is-selected', idx === index);
          });
        }
      });

      // Initially mark the active one based on Kaching checked radio or class
      setTimeout(function() {
        var cards = container.querySelectorAll('.kaching-bundles__deal, .kaching-bundles__deal-card, [class*="kaching-bundles__deal"], [class*="deal-card"]');
        cards.forEach(function(card, idx) {
          var isSelected = card.classList.contains('is-selected') || 
                           card.classList.contains('active') || 
                           card.querySelector('input[type="radio"]:checked') !== null ||
                           card.getAttribute('aria-checked') === 'true';
          if (isSelected && idx < 2) {
            var guideItems = document.querySelectorAll('.mx-beard-guide__item');
            if (guideItems[idx]) {
              guideItems[idx].classList.add('is-selected');
            }
          }
        });
      }, 1000);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupKachingSync);
    } else {
      setTimeout(setupKachingSync, 1000);
    }
  })();
</script>

<style>
  .mx-beard-guide {
    margin: 18px 0 20px 0;
    padding: 16px;
    background: #fdfdfb;
    border: 1px solid #e2dbca;
    border-radius: 8px;
    font-family: var(--mx-font-body), sans-serif;
  }

  .mx-beard-guide__title {
    font-family: var(--mx-font-display), sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #0c0b0a;
    text-transform: uppercase;
    margin: 0 0 14px 0 !important;
    text-align: center;
    border-bottom: 1px solid rgba(184, 154, 82, 0.15);
    padding-bottom: 6px;
  }

  .mx-beard-guide__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .mx-beard-guide__item {
    position: relative;
    background: #fff;
    border: 1px solid #e0d9c8;
    border-radius: 6px;
    padding: 18px 10px 14px 10px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 2px 6px rgba(0,0,0,0.01);
    cursor: pointer;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    user-select: none;
  }

  .mx-beard-guide__item:hover {
    transform: translateY(-2px);
    border-color: #b89a52;
    box-shadow: 0 6px 12px rgba(184, 154, 82, 0.12);
  }

  .mx-beard-guide__item.is-selected {
    border-color: #b89a52;
    background: #fffdf8;
    box-shadow: 0 4px 14px rgba(184, 154, 82, 0.22);
    transform: scale(1.02);
  }

  .mx-beard-guide__item.is-selected::after {
    content: '✓';
    position: absolute;
    top: 6px;
    right: 8px;
    font-size: 10px;
    font-weight: bold;
    color: #b89a52;
  }

  .mx-beard-guide__badge {
    position: absolute;
    top: -8px;
    left: 50%;
    transform: translateX(-50%);
    background: #8b8577;
    color: #fff;
    font-size: 8px;
    font-weight: 700;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: 100px;
    white-space: nowrap;
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .mx-beard-guide__badge--gold {
    background: #b89a52;
  }

  .mx-beard-guide__option {
    font-family: var(--mx-font-display), sans-serif;
    font-size: 16px;
    color: #0c0b0a;
    margin: 0 !important;
    text-transform: uppercase;
    font-weight: 700;
    line-height: 1.1;
  }

  .mx-beard-guide__duration {
    font-size: 11px;
    font-weight: 700;
    color: #b89a52;
    margin: 2px 0 6px 0 !important;
    text-transform: uppercase;
    line-height: 1;
  }

  .mx-beard-guide__points {
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: flex-start;
    width: 100%;
    margin: 10px 0 12px 0;
  }

  .mx-beard-guide__point {
    font-size: 10px;
    color: #494640;
    line-height: 1.35;
    position: relative;
    padding-left: 14px;
    text-align: left;
  }

  .mx-beard-guide__point::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #b89a52;
    font-weight: 700;
  }

  .mx-beard-guide__footer {
    font-size: 8.5px;
    font-style: italic;
    color: #7a7570;
    margin-top: auto !important;
    line-height: 1.3;
    border-top: 1px solid rgba(0,0,0,0.06);
    padding-top: 8px;
    width: 100%;
    text-align: center;
  }

  .mx-beard-guide__footer--gold {
    color: #b89a52;
    font-weight: 600;
  }

  /* Adaptación para temas oscuros */
  .m-color-dark .mx-beard-guide {
    background: #171512;
    border-color: rgba(184,154,82,0.2);
  }
  .m-color-dark .mx-beard-guide__title {
    color: #f5f2ea;
  }
  .m-color-dark .mx-beard-guide__item {
    background: #1e1b17;
    border-color: rgba(184,154,82,0.15);
  }
  .m-color-dark .mx-beard-guide__item:hover {
    border-color: #b89a52;
  }
  .m-color-dark .mx-beard-guide__item.is-selected {
    background: #25221d;
    border-color: #b89a52;
    box-shadow: 0 4px 16px rgba(184,154,82,0.3);
  }
  .m-color-dark .mx-beard-guide__option {
    color: #f5f2ea;
  }
  .m-color-dark .mx-beard-guide__point {
    color: #d4cfc4;
  }
  .m-color-dark .mx-beard-guide__footer {
    color: #a09a8f;
    border-top-color: rgba(255,255,255,0.06);
  }
  .m-color-dark .mx-beard-guide__footer--gold {
    color: #b89a52;
  }

  @media (max-width: 480px) {
    .mx-beard-guide {
      padding: 12px 10px;
    }
    .mx-beard-guide__grid {
      gap: 8px;
    }
    .mx-beard-guide__item {
      padding: 16px 4px 12px 4px;
    }
    .mx-beard-guide__option {
      font-size: 14px;
    }
    .mx-beard-guide__duration {
      font-size: 10px;
    }
    .mx-beard-guide__point {
      font-size: 9px;
      padding-left: 12px;
      line-height: 1.25;
    }
    .mx-beard-guide__footer {
      font-size: 8px;
      padding-top: 6px;
    }
    .mx-beard-guide__badge {
      font-size: 7.5px;
      padding: 1px 5px;
    }
  }
</style>
