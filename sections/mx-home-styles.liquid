<script>
  /* MX HOME — Performance optimizer (runs idle, doesn't block) */
  (function() {
    var run = function() {
      try {
        /* 1) Add decoding="async" + lazy loading to all images that don't have them */
        var imgs = document.querySelectorAll('img:not([decoding])');
        for (var i = 0; i < imgs.length; i++) {
          imgs[i].setAttribute('decoding', 'async');
          if (!imgs[i].hasAttribute('loading')) {
            /* Skip first 2 images (likely above fold) — let them load eager */
            if (i > 1) imgs[i].setAttribute('loading', 'lazy');
          }
        }
        /* 2) Lazy-load iframes (videos, embeds) */
        var iframes = document.querySelectorAll('iframe:not([loading])');
        for (var j = 0; j < iframes.length; j++) {
          iframes[j].setAttribute('loading', 'lazy');
        }
        /* 3) Hint browser to deprioritize tracking scripts via fetchpriority */
        var thirdPartyScripts = document.querySelectorAll('script[src*="analytics"], script[src*="gtag"], script[src*="facebook"]');
        for (var k = 0; k < thirdPartyScripts.length; k++) {
          if (!thirdPartyScripts[k].hasAttribute('fetchpriority')) {
            thirdPartyScripts[k].setAttribute('fetchpriority', 'low');
          }
        }
      } catch (e) { /* silent */ }
    };
    /* Defer until browser is idle, fall back to setTimeout */
    if ('requestIdleCallback' in window) {
      requestIdleCallback(run, { timeout: 2000 });
    } else {
      setTimeout(run, 800);
    }
  })();
</script>

