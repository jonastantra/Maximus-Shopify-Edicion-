          "type": "content",
          "settings": {
            "heading": "La Barberia",
            "content": "<div class=\"m-store-info\">\n  <div class=\"m-store-info__item\">\n      <h4>Dirección</h4>\n      <p class=\"m:text-color-subtext\">\n        Oriente 8 #177, Col. Reforma<br>\n        Nezahualcóyotl, Estado de México\n      </p>\n      <a href=\"https://www.google.com/maps/search/?api=1&amp;query=Oriente+8+%23177,+Col+Reforma,+Nezahualc%C3%B3yotl,+Estado+de+M%C3%A9xico\" target=\"_blank\">\n        Cómo llegar\n      </a>\n  </div>\n\n  <div class=\"m-store-info__item\">\n      <h4 class=\"h5\">Horarios</h4>\n      <p class=\"m:text-color-subtext\">\n        Lunes a sábado<br>\n        11:00 AM a 7:00 PM\n      </p>\n  </div>\n\n  <div class=\"m-store-info__item\">\n      <h4 class=\"h5\">Contáctanos</h4>\n      <p class=\"m:text-color-subtext\">\n        Escríbenos por WhatsApp y te atenderemos<br>\n        lo antes posible.\n      </p>\n      <p>\n        <a href=\"https://wa.me/5215572945816\" target=\"_blank\">+52 1 55 7294 5816</a>\n      </p>\n  </div>\n\n  <div class=\"m-store-info__item\">\n      <h4 class=\"h5\">Redes Sociales</h4>\n      <ul>\n        <li>\n          <a href=\"https://www.facebook.com/Labarberianz\" target=\"_blank\">\n            Facebook\n          </a>\n        </li>\n      </ul>\n  </div>\n</div>",
            "width": "50%"
          }
