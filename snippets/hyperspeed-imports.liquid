{%- assign preloads = shop.metaobjects['app--2675107--hyperspeed_image_preloads']['app--2675107--hyperspeed-image-preloads-axax8vfe'].image_preloads.value -%}

{% if template.name == 'index' %}
<!-- Preload LCP Image -->
{% assign base_url = 'https://' | append: request.host -%}
{%- for preload in preloads.home -%}
{%- assign preload_sizes = preload.sizes -%}
{%- assign preload_src = preload.src | replace: 'HS_URL_PLACEHOLDER', base_url -%}
{%- assign preload_srcset = preload.srcset | replace: 'HS_URL_PLACEHOLDER', base_url -%}
{%- assign preload_media = preload.media -%}
<link
    rel="preload"
    as="image"
    href="{{ preload_src }}"
    imagesrcset="{{ preload_srcset }}"
    imagesizes="{{ preload_sizes }}"
    media="{{ preload_media }}"
/>
{%- endfor -%}
{%- endif -%}

{% if template.name == 'product' %}
<!-- Preload LCP Product Image -->
{% for preload in preloads.product -%}
{%- assign preload_src_width = preload.src -%}
{%- assign preload_product = product.selected_or_first_available_variant.featured_media | default: product.featured_media -%}
{%- assign widths = preload.srcset | split: "," -%}
{%- if preload.tag_type == 'img_url' -%}
<link
    rel="preload"
    as="image"
    href="{{ preload_product.src | img_url: preload_src_width }}"
    imagesizes="{{ preload.sizes }}"
    {% if widths -%}imagesrcset="{% for width in widths %}{{ preload_product.src | img_url: width }} {{ width }}w{% unless forloop.last %}, {% endunless %}{% endfor %}"{%- endif -%}
/>
{%- elsif preload.tag_type == 'image_url' -%}
<link
    rel="preload"
    as="image"
    href="{{ preload_product.src | image_url: width: preload_src_width }}"
    imagesizes="{{ preload.sizes }}"
    {% if widths -%}imagesrcset="{% for width in widths %}{{ preload_product.src | image_url: width: width }} {{ width }}w{% unless forloop.last %}, {% endunless %}{% endfor %}"{%- endif -%}
/>
{%- endif -%}
{%- endfor -%}
{%- endif -%}

